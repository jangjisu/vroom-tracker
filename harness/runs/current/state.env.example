# 이 파일을 harness/runs/current/state.env 로 복사해서 현재 run 상태 파일로 사용한다.
#
# hook은 이 상태 파일을 읽어서 현재 작업 유형, 범위, 계획 문서,
# 스펙 영향도, 검증 로그, 커밋 메시지 등을 판단한다.

# 작업 유형.
# 예: backend-rest-api, public-api-integration, bugfix, frontend-change, fullstack-feature,
# documentation-harness, git-only
WORKFLOW=

# 이번 run에서 먼저 진행할 작업 범위.
# 예: backend, frontend, api-integration, documentation-harness, git
SCOPE=

# 감지된 카테고리 목록.
# 여러 개면 쉼표로 구분한다. 예: backend,frontend
CATEGORIES=

# 카테고리가 여러 개일 때 사용자에게 진행 순서를 확인했는지 여부.
CATEGORY_ORDER_CONFIRMED=false

# 계획 문서 경로.
PLAN_FILE=

# 우리 서버가 제공하는 API 스펙 영향 여부.
# 값: changed, unchanged
INTERNAL_API_SPEC_IMPACT=

# 외부 공공 API 연동 스펙 영향 여부.
# 값: changed, unchanged, not-applicable
EXTERNAL_API_SPEC_IMPACT=

# 스펙 확인 결과를 반영해 계획을 확정했는지 여부.
PLAN_FINALIZED=false

# 계획에서 비교한 접근 방법과 trade-off가 기록되었는지 여부.
TRADE_OFF_REVIEWED=false

# 개발팀장 관점 계획 리뷰 상태와 결과 파일.
# PLAN_ENG_REVIEW_STATUS 값: completed
PLAN_ENG_REVIEW_STATUS=
PLAN_ENG_REVIEW_FILE=

# 제품 가치와 범위 영향 여부, CEO 관점 리뷰 상태와 결과 파일.
# PRODUCT_IMPACT 값: true, false
# CEO_REVIEW_STATUS 값: completed, not-required
PRODUCT_IMPACT=false
CEO_REVIEW_STATUS=
CEO_REVIEW_FILE=

# 개발자 경험 리뷰 영향 여부와 실행 상태.
# DX_IMPACT 값: true, false
# DEVEX_REVIEW_STATUS 값: completed, not-required
DX_IMPACT=false
DEVEX_REVIEW_STATUS=
DEVEX_REVIEW_FILE=

# 보안 리뷰 영향 여부와 실행 상태.
# SECURITY_IMPACT 값: true, false
# SECURITY_REVIEW_STATUS 값: completed, not-required
SECURITY_IMPACT=false
SECURITY_REVIEW_STATUS=
SECURITY_REVIEW_FILE=

# 화면 구조와 사용자 흐름 영향 여부, Design 리뷰 상태와 결과 파일.
# DESIGN_IMPACT 값: true, false
# DESIGN_REVIEW_STATUS 값: completed, not-required
DESIGN_IMPACT=false
DESIGN_REVIEW_STATUS=
DESIGN_REVIEW_FILE=

# 사용자가 확정된 계획을 승인했는지 여부.
PLAN_APPROVED_BY_USER=false

# Compound Engineering 최종 코드 리뷰 상태.
# 값: completed
COMPOUND_CODE_REVIEW_STATUS=
COMPOUND_CODE_REVIEW_FILE=

# 재사용 가능한 학습 기록 상태.
# 값: completed, not-required
COMPOUND_KNOWLEDGE_STATUS=
COMPOUND_KNOWLEDGE_FILE=

# 검증 로그 파일 경로.
VERIFICATION_LOG=

# 화면/이미지 검증이 필요한 경우 스크린샷 디렉터리.
SCREENSHOT_DIR=

# 커밋 메시지 초안 파일 경로.
COMMIT_MESSAGE_FILE=

# Map/HashMap 사용에 대해 사용자 승인을 받았는지 여부.
MAP_USAGE_APPROVED=false
