# 운영 컨테이너 환경변수 템플릿.
# 실제 값을 채운 뒤 `.env` 로 복사하세요. (.env 는 git 에 올라가지 않습니다)
#   cp .env.example .env

# 한국도로공사 공공데이터 키 (data.ex.co.kr)
EX_API_KEY=replace-with-real-ex-api-key

# 카카오 REST API 키 — 서버 전용 시크릿
KAKAO_REST_API_KEY=replace-with-real-kakao-rest-api-key

# 네이버 지도 JS key id — 브라우저에 노출되므로 콘솔에서 도메인 제한 필수
NAVER_MAPS_NCP_KEY_ID=replace-with-real-naver-maps-ncp-key-id

# 오피넷 무료 API 키 — 전국 평균 주유 가격 조회용
OPINET_API_KEY=replace-with-real-opinet-api-key

# Caddy HTTPS reverse proxy 도메인
APP_DOMAIN=www.rest-route.o-r.kr

# MySQL 컨테이너와 Spring datasource 설정
MYSQL_DATABASE=vroom
MYSQL_USER=vroom
MYSQL_PASSWORD=replace-with-strong-mysql-password
MYSQL_ROOT_PASSWORD=replace-with-strong-root-password
